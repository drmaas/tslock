{
  "name": "@tslock/redis",
  "version": "1.0.0",
  "description": "TSLock Redis provider using node-redis",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@tslock/core": "workspace:*",
    "@tslock/redis-core": "workspace:*",
    "redis": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@tslock/core": { "optional": false },
    "@tslock/redis-core": { "optional": false },
    "redis": { "optional": false }
  },
  "devDependencies": {
    "@tslock/core": "workspace:*",
    "@tslock/redis-core": "workspace:*",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "redis": "^4.6.0"
  }
}
