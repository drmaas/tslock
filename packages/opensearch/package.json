{
  "name": "@tslock/opensearch",
  "version": "1.0.2",
  "description": "TSLock provider for OpenSearch",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@tslock/core": "workspace:*",
    "@opensearch-project/opensearch": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tslock/core": {
      "optional": false
    },
    "@opensearch-project/opensearch": {
      "optional": false
    }
  },
  "devDependencies": {
    "@tslock/core": "workspace:*",
    "@opensearch-project/opensearch": "^2.0.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drmaas/tslock.git",
    "directory": "packages/opensearch"
  }
}
