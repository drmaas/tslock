{
  "name": "tslock",
  "version": "1.0.0",
  "private": true,
  "description": "TSLock monorepo — distributed locks for scheduled tasks in TypeScript",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.12.0",

  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm check && pnpm test && pnpm build && changeset publish"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
